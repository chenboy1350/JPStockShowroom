<div id="page-title" data-title="พิมพ์รายงาน"></div>

<div class="container-fluid">
    <div class="card d-flex collapsed-card">
        <div class="card-header">
            <h3 class="card-title mb-0">
                <i class="fas fa-print mr-2"></i>พิมพ์รายงานการเบิก
            </h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body pb-0">
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label for="txtWithdrawalArticle">Article</label>
                        <input type="text" id="txtWithdrawalArticle" class="form-control" placeholder="กรอก Article">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label for="txtWithdrawalNo">เลขที่ใบเบิก</label>
                        <input type="text" id="txtWithdrawalNo" class="form-control" placeholder="เลขที่ใบเบิก">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label for="ddlWithdrawalEDesArt">ประเภทสินค้า (EDesArt)</label>
                        <select id="ddlWithdrawalEDesArt" class="form-control" style="width:100%">
                            <option value="">-- ทั้งหมด --</option>
                            @foreach (var pt in (ViewBag.ProductTypes as List<string> ?? new List<string>()))
                            {
                                <option value="@pt">@pt</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-group">
                        <button type="button" class="btn btn-primary mr-2" onclick="searchWithdrawal()">
                            <i class="fas fa-search mr-1"></i>ค้นหา
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="clearWithdrawalFilter()">
                            <i class="fas fa-times mr-1"></i>ล้าง
                        </button>
                    </div>
                </div>
            </div>
            <div class="d-flex align-items-end">
                <ul class="nav nav-tabs flex-grow-1" id="tabs-withdrawal" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="tab-withdrawal-headers-link" href="#" role="tab" onclick="switchWithdrawalTab('headers')">
                            <i class="fas fa-list mr-1"></i>ใบเบิก
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="tab-withdrawal-pending-link" href="#" role="tab" onclick="switchWithdrawalTab('pending')">
                            <i class="fas fa-clock mr-1"></i>รอสร้างใบเบิก
                            <span class="badge badge-warning ml-1" id="badge-pending-count" style="display:none"></span>
                        </a>
                    </li>
                </ul>
                <div id="toolbar-create-withdrawal" class="ml-2 pb-1" style="display:none">
                    <button class="btn btn-success btn-sm" onclick="createWithdrawalDocument()">
                        <i class="fas fa-file-alt mr-1"></i>สร้างใบเบิก
                    </button>
                    <small class="text-muted ml-1" id="lbl-pending-selected"></small>
                </div>
            </div>
            <div>
                <div id="tab-withdrawal-headers">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th class="text-center">#</th>
                                <th>เลขที่เบิก</th>
                                <th>วันที่</th>
                                <th class="text-center">จำนวนรายการ</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="tbl-withdrawal-headers-body">
                            <tr>
                                <td colspan="5" class="text-center text-muted p-3">กำลังโหลด...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div id="tab-withdrawal-pending" style="display:none">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th class="text-center">IMG</th>
                                <th>Article</th>
                                <th>OrderNo</th>
                                <th>EDesFn</th>
                                <th>ListGem</th>
                                <th class="text-center">จำนวน</th>
                                <th>หมายเหตุ</th>
                                <th class="text-center">Date</th>
                                <th class="text-center" style="width:40px">
                                    <input type="checkbox" id="chk-pending-all" class="custom-checkbox"
                                           onclick="toggleAllPending(this)">
                                </th>
                                <th style="width:40px"></th>
                            </tr>
                        </thead>
                        <tbody id="tbl-withdrawal-pending-body">
                            <tr>
                                <td colspan="10" class="text-center text-muted p-3">กำลังโหลด...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-withdrawal-detail">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">รายละเอียดการเบิก — <span id="lbl-withdrawal-no"></span></h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body p-0">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th class="text-center">IMG</th>
                            <th>Article</th>
                            <th>OrderNo</th>
                            <th>EDesFn</th>
                            <th>ListGem</th>
                            <th class="text-center">จำนวน</th>
                            <th>หมายเหตุ</th>
                            <th class="text-center">Date</th>
                        </tr>
                    </thead>
                    <tbody id="tbl-withdrawal-detail-body"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">ปิด</button>
            </div>
        </div>
    </div>
</div>


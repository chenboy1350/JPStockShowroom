<div class="container-fluid mt-3">
    <div class="card d-flex collapsed-card">
        <div class="card-header">
            <h3 class="card-title mb-0">
                <i class="fas fa-boxes mr-2"></i>พิมพ์รายงานสถานะสต็อค
            </h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label for="txtStockArticle">Article</label>
                        <input type="text" id="txtStockArticle" class="form-control" placeholder="กรอก Article">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label for="ddlStockEDesArt">ประเภทสินค้า (EDesArt)</label>
                        <select id="ddlStockEDesArt" class="form-control" style="width:100%">
                            <option value="">-- ทั้งหมด --</option>
                            @foreach (var pt in (ViewBag.ProductTypes as List<string> ?? new List<string>()))
                            {
                                <option value="@pt">@pt</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label for="ddlStockUnit">สถานะการลงทะเบียน</label>
                        <select id="ddlStockUnit" class="form-control" style="width:100%">
                            <option value="">-- ทั้งหมด --</option>
                            <option value="1">งาน Z ที่รอลงทะเบียน</option>
                            <option value="2">ลงทะเบียนแล้ว</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>OrderNo</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="text" id="txtStockOrderNoFrom" class="form-control" placeholder="จาก">
                            <span>-</span>
                            <input type="text" id="txtStockOrderNoTo" class="form-control" placeholder="ถึง">
                        </div>
                    </div>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-12 d-flex gap-2">
                    <button type="button" class="btn btn-secondary" onclick="printStockToPDF()">
                        <i class="fas fa-print mr-1"></i>พิมพ์รายงาน (รูป)
                    </button>
                    <button type="button" class="btn btn-info" onclick="printStockNoIMGToPDF()">
                        <i class="fas fa-list mr-1"></i>พิมพ์รายงาน
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    ['#ddlWithdrawalEDesArt', '#ddlBorrowEDesArt', '#ddlBreakEDesArt', '#ddlStockEDesArt', '#ddlStockUnit'].forEach(function (id) {
        if ($(id).hasClass('select2-hidden-accessible')) $(id).select2('destroy');
        $(id).select2({ placeholder: '-- ทั้งหมด --', allowClear: true, width: '100%' });
    });

    $('#ddlWithdrawalEDesArt').on('change', function () { searchWithdrawal(); });
    $('#txtWithdrawalArticle, #txtWithdrawalNo').on('keydown', function (e) { if (e.key === 'Enter') searchWithdrawal(); });

    $('#ddlBorrowEDesArt').on('change', function () { searchBorrow(); });
    $('#txtBorrowArticle, #txtBorrowNo').on('keydown', function (e) { if (e.key === 'Enter') searchBorrow(); });

    $('#ddlBreakEDesArt').on('change', function () { searchBreak(); });
    $('#txtBreakArticle, #txtBreakNo').on('keydown', function (e) { if (e.key === 'Enter') searchBreak(); });

    loadWithdrawalHeaders();
    loadPendingWithdrawals();
    loadBorrowHeaders();
    loadPendingBorrows();
    loadBreakHeaders();
    loadPendingBreaks();
</script>

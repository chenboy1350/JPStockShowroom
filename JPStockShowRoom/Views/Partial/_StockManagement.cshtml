</div>


<div class="modal fade" id="modal-add-break">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title"><i class="fas fa-plus-circle"></i> เพิ่มรายการเสียหาย</h4>
                <button type="button" class="close" onclick="$('#modal-add-break').modal('hide')" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="">
                    <label for="txtBreakQty">กรอกจำนวนที่เสียหาย</label>
                    <input type="number" min="0" id="txtBreakQty" step="0.5" class="form-control">
                    <label for="ddlBreakDes"><span style="color:red;">*</span> อาการที่ชำรุด</label>
                    <select id="ddlBreakDes" name="ddlBreakDes" class="form-control" style="width: 100%">
                        <option value="" selected>-- เลือกอาการ --</option>
                        @foreach (var des in ViewBag.BreakDescriptions)
                        {
                            <option value="@des.BreakDescriptionId">@des.Name</option>
                        }
                    </select>
                    <label for="txtAddBreakDes">เพิ่มใหม่</label>
                    <div class="input-group">
                        <input type="text" id="txtAddBreakDes" class="form-control" placeholder="อาการที่ชำรุด" style="display:none;">
                        <span class="input-group-append">
                            <button type="button" id="btnAddBreakDes" class="btn btn-info btn-flat"><i class="fas fa-plus"></i></button>
                        </span>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-end">
                <button type="button" class="btn btn-info" id="btnAddBreak">ยืนยัน</button>
            </div>
        </div>
    </div>
</div>

@{
    var convertedItems = ViewBag.ConvertedItems as List<JPStockShowRoom.Models.ConvertedArticleModel> ?? new List<JPStockShowRoom.Models.ConvertedArticleModel>();
}

@if (convertedItems.Count > 0)
{
    <div class="modal fade" id="modal-z-converted" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h4 class="modal-title">
                        <i class="fas fa-sync-alt me-2"></i>
                        อัพเดทรหัสสินค้า Z เสร็จสิ้น
                    </h4>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle me-1"></i>
                        พบและอัพเดท <strong>@convertedItems.Count รายการ</strong> ที่ลงทะเบียนแล้ว จาก Z article เป็น article จริงเรียบร้อย
                    </div>
                    <div class="table-responsive" style="max-height: 55vh; overflow-y: auto;">
                        <table class="table table-sm table-bordered table-hover text-nowrap">
                            <thead class="thead-light">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th>Z Article</th>
                                    <th>Article จริง</th>
                                    <th>ประเภท</th>
                                    <th>Barcode เก่า</th>
                                    <th>Barcode ใหม่</th>
                                    <th>Order No</th>
                                    <th>Lot No</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < convertedItems.Count; i++)
                                {
                                    var item = convertedItems[i];
                                    <tr>
                                        <td class="text-center">@(i + 1)</td>
                                        <td><span class="badge badge-warning">@item.ZArticle</span></td>
                                        <td><strong>@item.RealArticle</strong></td>
                                        <td>@item.EdesArt</td>
                                        <td class="text-muted"><small>@item.OldBarcode</small></td>
                                        <td><code>@item.NewBarcode</code></td>
                                        <td>@item.OrderNo</td>
                                        <td>@item.LotNo</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-dismiss="modal">
                        <i class="fas fa-check me-1"></i> รับทราบ
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="modal-add-stock">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title"><i class="fas fa-plus-circle mr-2"></i>เพิ่มสินค้าเข้า Stock</h4>
                <button type="button" class="close" onclick="$('#modal-add-stock').modal('hide')" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-5">
                        <div class="form-group">
                            <label>Article</label>
                            <input type="text" id="txtAddStockArticle" class="form-control" placeholder="กรอก Article"
                                   onkeydown="if(event.key==='Enter') searchAddStockArticle()">
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="form-group">
                            <label>Barcode</label>
                            <input type="text" id="txtAddStockBarcode" class="form-control" placeholder="กรอก Barcode"
                                   onkeydown="if(event.key==='Enter') searchAddStockArticle()">
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-group d-flex gap-1">
                            <button class="btn btn-primary" type="button" onclick="searchAddStockArticle()" title="ค้นหา">
                                <i class="fas fa-search"></i>
                            </button>
                            <button class="btn btn-secondary" type="button" onclick="clearAddStockSearch()" title="ล้างค่า">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>เลือกรายการ <span class="text-danger">*</span></label>
                    <select id="ddlAddStockBarcode" class="form-control" style="width:100%" onchange="onAddStockBarcodeChange()">
                        <option value="">-- ค้นหาก่อน --</option>
                    </select>
                </div>

                <div id="add-stock-item-info" style="display:none">
                    <div class="card bg-light mb-3">
                        <div class="card-body py-2 px-3">
                            <div class="row text-sm">
                                <div class="col-6">
                                    <small class="text-muted">Article</small>
                                    <div id="info-add-stock-article" class="font-weight-bold"></div>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">EdesArt</small>
                                    <div id="info-add-stock-edesart"></div>
                                </div>
                                <div class="col-6 mt-1">
                                    <small class="text-muted">EDesFn</small>
                                    <div id="info-add-stock-edesfn"></div>
                                </div>
                                <div class="col-6 mt-1">
                                    <small class="text-muted">ListGem</small>
                                    <div id="info-add-stock-listgem"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>จำนวนที่เพิ่ม <span class="text-danger">*</span></label>
                    <input type="number" id="txtAddStockQty" class="form-control" min="0.5" step="0.5" value="" placeholder="0.0" style="max-width:180px">
                </div>
            </div>
            <div class="modal-footer justify-content-end">
                <button type="button" class="btn btn-success" id="btnConfirmAddStock" onclick="confirmAddStock()">
                    <i class="fas fa-save mr-1"></i>บันทึก
                </button>
                <button type="button" class="btn btn-default" onclick="$('#modal-add-stock').modal('hide')">ปิด</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-import-excel">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title"><i class="fas fa-file-excel mr-2"></i>นำเข้าสินค้าจาก Excel</h4>
                <button type="button" class="close" onclick="$('#modal-import-excel').modal('hide')" aria-label="Close">
                    <span>&times;</span>

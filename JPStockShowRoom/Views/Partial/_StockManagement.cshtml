                                    <th class="text-center">แถว</th>
                                    <th>Article</th>
                                    <th>Barcode</th>
                                    <th class="text-end">Qty</th>
                                    <th>สาเหตุ</th>
                                </tr>
                            </thead>
                            <tbody id="tbl-import-excel-body"></tbody>
                        </table>
                    </div>
                </div>

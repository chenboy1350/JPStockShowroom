            <div class="modal-footer justify-content-end">
                <button type="button" class="btn btn-success" id="btnConfirmImportExcel" onclick="confirmImportExcel()">
                    <i class="fas fa-upload mr-1"></i>นำเข้า
                </button>
                <button type="button" class="btn btn-secondary" id="btnImportExcelBack" style="display:none;" onclick="resetImportExcelModal()">
                    <i class="fas fa-arrow-left mr-1"></i>นำเข้าอีกครั้ง
                </button>
                <button type="button" class="btn btn-default" onclick="$('#modal-import-excel').modal('hide')">ปิด</button>
            </div>
        </div>
    </div>
</div>

<div id="page-title" data-title="จัดการ Stock"></div>

<script>

    @{
        var articleList = ViewBag.Articles as List<string> ?? new List<string>();
        var articlesJson = System.Text.Json.JsonSerializer.Serialize(articleList);
    }
    if (typeof _allArticles !== 'undefined') {
        _allArticles = @Html.Raw(articlesJson);
    }

    ['#ddlEDesArt', '#ddlUnit'].forEach(function (id) {
        if ($(id).hasClass('select2-hidden-accessible')) $(id).select2('destroy');
        $(id).select2({ placeholder: '-- ทั้งหมด --', allowClear: true, width: '100%' })
             .on('change', function () { onFilterDDLChange(); });
    });

    if (typeof switchStockTab === 'function') switchStockTab('general');
    if (typeof _selectedArticle !== 'undefined') _selectedArticle = null;
    $('#txtArticleSearch').val('');
    $('#ddlEDesArt').val('').trigger('change');
    $('#ddlUnit').val('').trigger('change');
    if (typeof renderArticlePanel === 'function') renderArticlePanel(_allArticles);
    if (typeof findStock === 'function') findStock(1);
    if (typeof loadTrayList === 'function') loadTrayList();

    @if (convertedItems.Count > 0)
    {
        <text>
    setTimeout(() => $('#modal-z-converted').modal('show'), 600);
        </text>
    }

    function printStockReportCurrent() {
        const article = ($('#txtArticleSearch').val() || '').trim() || null;
        const edesArt = $('#ddlEDesArt').val() || null;
        const registrationStatusRaw = $('#ddlUnit').val();
        const registrationStatus = registrationStatusRaw ? parseInt(registrationStatusRaw) : null;
        printStockToPDF(article, edesArt, null, registrationStatus);
    }

    function printStockNoIMGCurrent() {
        const article = ($('#txtArticleSearch').val() || '').trim() || null;
        const edesArt = $('#ddlEDesArt').val() || null;
        const registrationStatusRaw = $('#ddlUnit').val();
        const registrationStatus = registrationStatusRaw ? parseInt(registrationStatusRaw) : null;
        printStockNoIMGToPDF(article, edesArt, null, registrationStatus);
    }
</script>
